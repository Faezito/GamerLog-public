<footer class="gl-footer w-100 bottom-0" style="z-index: 100;">

    <div class="gl-footer-pip gl-footer-pip--tl" aria-hidden="true"></div>
    <div class="gl-footer-pip gl-footer-pip--tr" aria-hidden="true"></div>

    <div class="gl-footer-body">
        <div class="container-fluid">
            <div class="row g-4">

                <div class="col-12 col-md-4 col-lg-3">
                    <a asp-controller="Home" asp-action="Index" class="gl-footer-brand">
                        <span class="logo-bracket">[</span>GL<span class="logo-bracket">]</span>
                        GAMERLOG
                    </a>
                    <span class="gl-footer-tagline">Registre · Explore · Evolua</span>

                    <div class="gl-footer-meta mb-3">
                        <div class="gl-footer-meta-item">
                            <span class="gl-footer-meta-label">Versão</span>
                            <span class="gl-footer-meta-value">v2.00</span>
                        </div>
                        <div class="gl-footer-meta-item">
                            <span class="gl-footer-meta-label">Build</span>
                            <span class="gl-footer-meta-value">2026.03</span>
                        </div>
                    </div>
                </div>

                <div class="col-6 col-md-4 col-lg-3">
                    <p class="gl-footer-heading">Navegação</p>
                    <ul class="gl-footer-links">
                        <li>
                            <a asp-controller="Usuario" asp-action="Index" class="gl-footer-link">
                                Início
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Rawg" asp-action="Index" class="gl-footer-link">
                                Biblioteca
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="col-6 col-md-4 col-lg-3">
                    <p class="gl-footer-heading">Conta</p>
                    <ul class="gl-footer-links">
                        <li>
                            <a asp-controller="Usuario" asp-action="Edicao" class="gl-footer-link">
                                Perfil
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Home" asp-action="Logout" class="gl-footer-link">
                                Sair
                            </a>
                        </li>
                    </ul>
                </div>

                @* <div class="col-12 col-lg-3">
                    <p class="gl-footer-heading">Sistema</p>
                    <ul class="gl-footer-links">
                        @if (User.IsInRole("Admin"))
                        {
                            <li>
                                <a asp-controller="Admin" asp-action="Index" class="gl-footer-link">
                                    Painel Admin
                                </a>
                            </li>
                        }
                    </ul>
                </div> *@

            </div>
        </div>
    </div>

    <hr class="gl-footer-divider">

    <div class="gl-footer-bottom">
        <span class="gl-footer-copyright">
            &copy; <span>@DateTime.Now.Year</span> GamerLog — Todos os direitos reservados
        </span>
        <span class="gl-footer-copyright">
            SYS::<span>GAMERLOG</span> &nbsp;·&nbsp; BUILD::<span>STABLE</span>
        </span>
    </div>

</footer>
