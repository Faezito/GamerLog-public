@model UsuarioModel
@{
    ViewData["Title"] = "GamerLog — Organizando sua jogatina";
    Layout = "_Layout";
}


<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />


<!-- ── Fundo com grid ── -->
<div class="bg-grid"></div>

<!-- ── Cantos HUD ── -->
<div class="hud-corner hud-tl"></div>
<div class="hud-corner hud-tr"></div>
<div class="hud-corner hud-bl"></div>
<div class="hud-corner hud-br"></div>

<!-- ── Achievement Toast ── -->
<div class="achievement-toast" id="achToast">
    <div class="ach-shine"></div>
    <div class="ach-icon">🏆</div>
    <div class="ach-text">
        <div class="ach-label">Achievement Unlocked</div>
        <div class="ach-name">Primeiro Log</div>
        <div class="ach-desc">Registre sua primeira jogatina</div>
    </div>
</div>

<!-- NAV -->
<nav>
    <a class="nav-logo" href="#">
        <span class="logo-bracket">[</span>GamerLog<span class="logo-bracket">]</span>
    </a>
    <div class="nav-right">
        <a href="#features" class="nav-link">Funções</a>
        <a href="#achievements" class="nav-link">Conquistas</a>
        <a href="https://portfolio2025-vm6w.onrender.com/" target="_blank" class="nav-link">Dev</a>
        <button class="btn-hud" data-bs-toggle="modal" data-bs-target="#modalLogin">
            <span>» Entrar</span>
        </button>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div class="hero-orb"></div>

    <!-- Grade synthwave -->
    <div class="hero-horizon">
        <svg class="horizon-grid" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" viewBox="0 0 1200 300">
            <line x1="0" y1="300" x2="1200" y2="300" />
            <line x1="100" y1="240" x2="1100" y2="240" />
            <line x1="220" y1="190" x2="980" y2="190" />
            <line x1="320" y1="150" x2="880" y2="150" />
            <line x1="400" y1="118" x2="800" y2="118" />
            <line x1="460" y1="93" x2="740" y2="93" />
            <line x1="510" y1="73" x2="690" y2="73" />
            <line x1="600" y1="0" x2="0" y2="300" />
            <line x1="600" y1="0" x2="1200" y2="300" />
            <line x1="600" y1="60" x2="0" y2="300" />
            <line x1="600" y1="60" x2="1200" y2="300" />
            <line x1="600" y1="100" x2="0" y2="300" />
            <line x1="600" y1="100" x2="1200" y2="300" />
            <line x1="600" y1="130" x2="0" y2="300" />
            <line x1="600" y1="130" x2="1200" y2="300" />
            <line x1="600" y1="155" x2="0" y2="300" />
            <line x1="600" y1="155" x2="1200" y2="300" />
            <line x1="600" y1="175" x2="0" y2="300" />
            <line x1="600" y1="175" x2="1200" y2="300" />
            <line x1="600" y1="192" x2="0" y2="300" />
            <line x1="600" y1="192" x2="1200" y2="300" />
            <line x1="600" y1="208" x2="0" y2="300" />
            <line x1="600" y1="208" x2="1200" y2="300" />
        </svg>
    </div>

    <div class="hud-status">
        <span class="dot"></span>
        <span>SISTEMA ONLINE</span>
        <span class="sep">|</span>
        <span>v1.04</span>
        <span class="sep">|</span>
        <span>GRATUITO</span>
    </div>

    <h1 class="hero-title" data-text="GamerLog">
        <span class="t1">GAMER</span>
        <span class="t2">LOG</span>
    </h1>

    <p class="hero-tagline">// <span class="accent">Organizando</span> sua jogatina</p>

    <p class="hero-sub">
        Registre cada partida, acompanhe seu backlog, avalie seus jogos e
        visualize estatísticas da sua jornada como gamer.
    </p>

    <div class="xp-bar-wrap">
        <div class="xp-label">
            <span>XP ACUMULADO</span>
            <span id="xpCount">0 / 1000 XP</span>
        </div>
        <div class="xp-track">
            <div class="xp-fill" id="xpFill"></div>
        </div>
    </div>

    <div class="hero-ctas">
        <button class="btn-primary-hud" data-bs-toggle="modal" data-bs-target="#modalLogin">
            Iniciar Jornada
        </button>
        <a href="#features" class="btn-outline-hud">Ver Funções ↓</a>
    </div>
</section>

<!-- STATS HUD -->
<div class="stats-hud">
    <div class="stat-hud">
        <span class="stat-num-hud">100%</span>
        <span class="stat-lbl-hud">Gratuito</span>
    </div>
    <div class="stat-hud">
        <span class="stat-num-hud">4</span>
        <span class="stat-lbl-hud">Módulos</span>
    </div>
    <div class="stat-hud">
        <span class="stat-num-hud">∞</span>
        <span class="stat-lbl-hud">Jogos</span>
    </div>
    <div class="stat-hud">
        <span class="stat-num-hud">v1.04</span>
        <span class="stat-lbl-hud">Build</span>
    </div>
</div>

<!-- FEATURES -->
<section class="gl-section reveal" id="features">
    <div class="section-eyebrow">MÓDULOS DO SISTEMA</div>
    <h2 class="section-title">Tudo que você precisa para <em>dominar</em> seu backlog</h2>

    <div class="features-grid">

        <div class="feat-card">
            <div class="feat-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                </svg>
            </div>
            <div class="feat-body">
                <div class="feat-num">MOD_01</div>
                <div class="feat-title">Registro de Partidas</div>
                <p class="feat-desc">Documente cada sessão com data, duração, plataforma e notas. Seu histórico completo, sempre acessível.</p>
            </div>
        </div>

        <div class="feat-card">
            <div class="feat-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />
                </svg>
            </div>
            <div class="feat-body">
                <div class="feat-num">MOD_02</div>
                <div class="feat-title">Backlog & Wishlist</div>
                <p class="feat-desc">Organize sua fila de jogos por status — jogando, zerado, pausado, na wishlist. Nunca perca o fio da meada.</p>
            </div>
        </div>

        <div class="feat-card">
            <div class="feat-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
            </div>
            <div class="feat-body">
                <div class="feat-num">MOD_03</div>
                <div class="feat-title">Avaliações & Reviews</div>
                <p class="feat-desc">Dê sua nota, escreva um mini-review pessoal. Suas impressões registradas para sempre, sem depender de plataformas externas.</p>
            </div>
        </div>

        <div class="feat-card">
            <div class="feat-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
            </div>
            <div class="feat-body">
                <div class="feat-num">MOD_04</div>
                <div class="feat-title">Stats & Analytics</div>
                <p class="feat-desc">Horas por jogo, gêneros favoritos, ritmo de jogatina, ranking pessoal. Visualize sua evolução como gamer.</p>
            </div>
        </div>

    </div>
</section>

<!-- SHOWCASE -->
<section class="showcase reveal">

    <!-- Mockup HUD -->
    <div class="">
        <img src="~/img/registros.png" class="col-12" />
    </div>

    <!-- Texto -->
    <div class="showcase-text">
        <div class="section-eyebrow">SEU PERFIL</div>
        <h2 class="section-title">Sua biblioteca. <em>Seu histórico.</em></h2>
        <p>
            Tenha uma visão completa de tudo que você jogou, está jogando e quer jogar.
            Com status, plataforma, horas e avaliações num painel limpo e rápido.
        </p>
        <ul class="feat-bullets">
            <li>Status: Jogando / Zerado / Pausado / Wishlist</li>
            <li>Registro de horas por sessão</li>
            <li>Notas e avaliações pessoais</li>
            <li>Filtros por plataforma e gênero</li>
            <li>Timeline da sua jogatina</li>
        </ul>
    </div>

</section>

