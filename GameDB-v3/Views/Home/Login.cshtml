<!-- CTA -->
<section class="cta-wrap reveal">
    <div class="pixel-bg">
        <canvas id="pixelCanvas"></canvas>
    </div>
    <div class="cta-inner">
        <h2>Pronto para<br><em>iniciar sua jornada?</em></h2>
        <p class="cta-sub">// GRATUITO · FEITO POR GAMER PARA GAMER</p>
        <button class="btn-primary-hud" data-bs-toggle="modal" data-bs-target="#modalLogin">
            » Criar Conta Grátis
        </button>
    </div>
</section>

<!-- MODAL LOGIN  -->
<div class="modal fade" id="modalLogin" tabindex="-1" aria-labelledby="modalLoginLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content gl-modal-content">

            <button type="button" class="gl-modal-close" data-bs-dismiss="modal" aria-label="Fechar">[ ESC ]</button>

            <div class="modal-logo">
                <span class="bracket">[</span>GamerLog<span class="bracket">]</span>
            </div>
            <p class="modal-sub">// Organizando sua jogatina</p>

            @if (ViewData["MSG_E"] != null)
            {
                <div class="alert alert-danger fw-bold mb-3">@ViewData["MSG_E"]</div>
            }

            <form id="form-login" method="post">
                <div class="field-group">
                    <label class="field-label" for="Login">Usuário ou E-mail</label>
                    <input id="Login" name="Login" type="text" class="field-input" placeholder="seu_usuario" required />
                </div>

                <div class="field-group">
                    <label class="field-label" for="Senha">Senha</label>
                    <input id="Senha" name="Senha" type="password" class="field-input" placeholder="••••••••" required />
                </div>

                <div class="modal-links">
                    <a asp-action="Cadastro" asp-controller="Home">Cadastre-se</a>
                    <a href="#" data-bs-dismiss="modal" data-bs-toggle="modal" data-bs-target="#modalRecuperarSenha">
                        Esqueci minha senha
                    </a>
                </div>

                <button type="submit" class="btn-modal-submit" id="btnLogin">
                    <span id="texto-login">» ACESSAR</span>
                    <span id="loading-login" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
            </form>

            <div class="modal-divider"><span>OU</span></div>

            <a asp-action="LoginGoogle" asp-controller="GoogleLogin" class="btn-google-hud">
                <i class="fa-brands fa-google"></i>
                Entrar com Google
            </a>

            <a asp-action="LoginSteam" asp-controller="Steam" class="btn-steam-hud mt-2">
                <i class="fa-brands fa-steam"></i>
                Entrar com Steam
            </a>

        </div>
    </div>
</div>

<!-- MODAL RECUPERAR SENHA -->
<div class="modal fade" id="modalRecuperarSenha" tabindex="-1" aria-labelledby="modalRecuperarSenhaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content gl-modal-content">

            <button type="button" class="gl-modal-close" data-bs-dismiss="modal" aria-label="Fechar">[ ESC ]</button>

            <div class="modal-logo" style="font-size: 1.1rem;">RECUPERAR SENHA</div>
            <p class="modal-sub">// Informe seu e-mail para receber o código</p>

            <form id="form-recuperar">
                <div class="field-group">
                    <label class="field-label" for="email">E-mail</label>
                    <input type="email" class="field-input" name="email" id="email"
                           placeholder="seu@email.com" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <button type="button" id="recuperar-senha" class="btn-modal-submit mt-2">
                    <span id="texto-salvar">Enviar código</span>
                    <span id="loading-recuperar" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/landing.js" asp-append-version="true"></script>
}
